# Ignore everything by default
*

# Whitelist root meta files
!.gitignore
!.gitattributes
!README.md
!README.txt
!riddletech-logo.png

# Whitelist assets folder and logo
!assets/
!assets/*

# Whitelist build distribution files
!dist/
dist/*
!dist/Go_Stealth_Setup.exe
!dist/Go-Stealth-x64.zip

# Whitelist website files
!go stealth website/
!go stealth website/*
!website/
!website/*

# Whitelist packaging configurations
!setup.iss

# Whitelist payment-admin (exclude JSON database files)
!payment-admin/
!payment-admin/*
payment-admin/keys.json
payment-admin/transactions.json
payment-admin/secret.json
